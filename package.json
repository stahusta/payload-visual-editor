{
  "name": "payload-visual-editor",
  "version": "0.1.0",
  "description": "Visual Editor plugin for Payload CMS 3.x - inline editing, block management, drag & drop, and contextual field editors in Live Preview",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "import": "./src/exports/client.ts",
      "types": "./src/exports/client.ts",
      "default": "./src/exports/client.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "npm run copyfiles && npm run build:types && npm run build:swc",
    "build:swc": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "copyfiles": "copyfiles -u 1 \"src/**/*.css\" dist/",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "@payloadcms/ui": "^3.0.0",
    "payload": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@payloadcms/ui": "^3.78.0",
    "@swc/cli": "^0.4.0",
    "@swc/core": "^1.7.0",
    "@types/react": "^19.2.14",
    "copyfiles": "^2.4.1",
    "payload": "^3.78.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.0.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./client": {
        "import": "./dist/exports/client.js",
        "types": "./dist/exports/client.d.ts",
        "default": "./dist/exports/client.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "keywords": [
    "payload",
    "payload-plugin",
    "visual-editor",
    "live-preview",
    "inline-editing",
    "cms"
  ]
}
